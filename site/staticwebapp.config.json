{
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": [
      "/aigraph/*",
      "/guides/*",
      "/assets/*",
      "/styles.css",
      "/robots.txt",
      "/sitemap.xml",
      "/llms.txt"
    ]
  },
  "globalHeaders": {
    "X-Content-Type-Options": "nosniff",
    "X-Frame-Options": "DENY",
    "Referrer-Policy": "strict-origin-when-cross-origin"
  }
}
