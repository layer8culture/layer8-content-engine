# --- Layer8Culture content engine ---

# Generated visuals (regenerated by the workflow; do not version)
assets/generated/*
!assets/generated/.gitkeep

# Per-day generated PNGs in the queue (keep .json / .summary.md / .gitkeep)
queue/*.png

# Never commit large binaries / installers (GitHub rejects >100MB)
*.exe

# Keep the brand reference files in assets/library/ (NOT ignored):
#   layer8-wordmark.png, layer8-style-reference-01.png, lofi-style-reference-01.png

# --- Python ---
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.env
*.env

# --- OS / editor noise ---
.DS_Store
Thumbs.db
.idea/
.vscode/
